<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dashboardRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF3F8"
    android:padding="20dp">

    <LinearLayout
        android:id="@+id/headerBar"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:background="#FFFFFF"
        android:elevation="3dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="18dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/headerTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="GridSync"
            android:textColor="#14213D"
            android:textSize="24sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/settingsIcon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:contentDescription="Settings"
            android:focusable="true"
            android:padding="6dp"
            android:src="@android:drawable/ic_menu_manage" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/statusBar"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginTop="14dp"
        android:background="#FFFFFF"
        android:elevation="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerBar">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@android:drawable/stat_notify_sync_noanim" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Network Status:"
            android:textColor="#5B6576"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/networkStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="Connected"
            android:textColor="#14213D"
            android:textSize="14sp"
            android:textStyle="bold" />

        <Space
            android:layout_width="28dp"
            android:layout_height="1dp" />

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@android:drawable/ic_menu_share" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Connected Watches:"
            android:textColor="#5B6576"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/watchCountText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="9 / 11"
            android:textColor="#14213D"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/createPlayCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="10dp"
        android:background="@drawable/card_background"
        android:clickable="true"
        android:elevation="4dp"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintBottom_toTopOf="@id/assignWatchesCard"
        app:layout_constraintEnd_toStartOf="@id/playLibraryCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/statusBar">

        <ImageView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@android:drawable/ic_input_add" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Create New Play"
            android:textColor="#1B263B"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/playLibraryCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:background="@drawable/card_background"
        android:clickable="true"
        android:elevation="4dp"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintBottom_toTopOf="@id/sendPlayCard"
        app:layout_constraintEnd_toStartOf="@id/playerStatusPanel"
        app:layout_constraintStart_toEndOf="@id/createPlayCard"
        app:layout_constraintTop_toBottomOf="@id/statusBar">

        <ImageView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@android:drawable/ic_menu_agenda" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Play Library"
            android:textColor="#1B263B"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/assignWatchesCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="14dp"
        android:background="@drawable/card_background"
        android:clickable="true"
        android:elevation="4dp"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintBottom_toTopOf="@id/sessionLogPanel"
        app:layout_constraintEnd_toStartOf="@id/sendPlayCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/createPlayCard">

        <ImageView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@android:drawable/ic_menu_myplaces" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Assign Watches"
            android:textColor="#1B263B"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/sendPlayCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="14dp"
        android:background="@drawable/card_background"
        android:clickable="true"
        android:elevation="4dp"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintBottom_toTopOf="@id/sessionLogPanel"
        app:layout_constraintEnd_toStartOf="@id/playerStatusPanel"
        app:layout_constraintStart_toEndOf="@id/assignWatchesCard"
        app:layout_constraintTop_toBottomOf="@id/playLibraryCard">

        <ImageView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@android:drawable/ic_menu_send" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Send Play"
            android:textColor="#1B263B"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/playerStatusPanel"
        android:layout_width="250dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/card_background"
        android:elevation="4dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/sessionLogPanel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/statusBar">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:text="Player Status"
            android:textColor="#1B263B"
            android:textSize="20sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp">

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="9dp" android:text="QB                                Online" android:textColor="#1F2937" android:textSize="16sp" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="9dp" android:text="WR1                              Online" android:textColor="#1F2937" android:textSize="16sp" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="9dp" android:text="WR2                              Online" android:textColor="#1F2937" android:textSize="16sp" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="9dp" android:text="RB                                Online" android:textColor="#1F2937" android:textSize="16sp" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="9dp" android:text="TE                                Online" android:textColor="#1F2937" android:textSize="16sp" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="9dp" android:text="LT                                Online" android:textColor="#1F2937" android:textSize="16sp" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="9dp" android:text="LG                                Online" android:textColor="#1F2937" android:textSize="16sp" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="9dp" android:text="C                                  Online" android:textColor="#1F2937" android:textSize="16sp" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="9dp" android:text="RG                                Online" android:textColor="#1F2937" android:textSize="16sp" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="9dp" android:text="LB                                Offline" android:textColor="#7B8794" android:textSize="16sp" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="9dp" android:text="CB                                Offline" android:textColor="#7B8794" android:textSize="16sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/sessionLogPanel"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:background="@drawable/card_background"
        android:elevation="4dp"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Session Activity Log"
            android:textColor="#1B263B"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text='14:32 - Play "Power Sweep Left" sent successfully'
            android:textColor="#52606D"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="14:30 - 9 devices acknowledged"
            android:textColor="#52606D"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="14:28 - Player assignments updated"
            android:textColor="#52606D"
            android:textSize="14sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>