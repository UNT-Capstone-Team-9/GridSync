<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#F7F9FC"
    android:padding="20dp">

    <!-- LEFT SIDE -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="2.5"
        android:orientation="vertical"
        android:paddingEnd="16dp">

        <EditText
            android:id="@+id/messageInput"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#FFFFFF"
            android:gravity="top|start"
            android:hint="Type your message..."
            android:padding="20dp"
            android:textSize="22sp"
            android:textColor="#000000"
            android:textColorHint="#777777" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.3" />

        <Button
            android:id="@+id/sendButton"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Send"
            android:textSize="20sp"
            android:textAllCaps="false" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.7" />
    </LinearLayout>

    <!-- RIGHT SIDE -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.5"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="16dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="70dp"
                android:layout_height="wrap_content"
                android:text="Role"
                android:textStyle="bold"
                android:textSize="16sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Status"
                android:textStyle="bold"
                android:textSize="16sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✔"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- QB -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="10dp">

            <TextView
                android:layout_width="70dp"
                android:layout_height="wrap_content"
                android:text="QB"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/statusQB"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Disconnected"
                android:textSize="15sp"
                android:textColor="#B00020" />

            <CheckBox
                android:id="@+id/checkQB"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true" />
        </LinearLayout>

        <!-- WR1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="10dp">

            <TextView
                android:layout_width="70dp"
                android:layout_height="wrap_content"
                android:text="WR1"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/statusWR1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Disconnected"
                android:textSize="15sp"
                android:textColor="#B00020" />

            <CheckBox
                android:id="@+id/checkWR1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- WR2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="10dp">

            <TextView
                android:layout_width="70dp"
                android:layout_height="wrap_content"
                android:text="WR2"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/statusWR2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Disconnected"
                android:textSize="15sp"
                android:textColor="#B00020" />

            <CheckBox
                android:id="@+id/checkWR2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- RB -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="10dp">

            <TextView
                android:layout_width="70dp"
                android:layout_height="wrap_content"
                android:text="RB"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/statusRB"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Disconnected"
                android:textSize="15sp"
                android:textColor="#B00020" />

            <CheckBox
                android:id="@+id/checkRB"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- TE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="10dp">

            <TextView
                android:layout_width="70dp"
                android:layout_height="wrap_content"
                android:text="TE"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/statusTE"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Disconnected"
                android:textSize="15sp"
                android:textColor="#B00020" />

            <CheckBox
                android:id="@+id/checkTE"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>